# Supabase (PUBLIC_ 권장, VITE_ fallback 지원)
PUBLIC_SUPABASE_URL=your_supabase_url_here
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only (Vercel Production/Preview)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# TossPayments
VITE_TOSS_CLIENT_KEY=your_toss_client_key_here

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# Claude API
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Firebase Cloud Messaging
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Logistics API
VITE_CHAINLOGIS_API_KEY=your_chainlogis_api_key_here

# App Settings
VITE_APP_ENV=development
VITE_APP_URL=http://localhost:5173
