#!/bin/sh

# nvm PATH 주입 (git 훅 환경에서 npx를 찾지 못하는 문제 방지)
export PATH="$HOME/.nvm/versions/node/v22.23.0/bin:$PATH"

echo ""
echo "🔍 Harness pre-commit 검사 시작 (staged 파일만)..."

STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ -z "$STAGED" ]; then
  echo "  스테이징된 변경 없음 — 검사 생략."
  echo ""
  echo "✅ Harness pre-commit 검사 통과."
  echo ""
  exit 0
fi

# [H-01~H-05] ESLint — lint-staged (staged .ts/.svelte만)
echo "  ESLint 검사 (staged)..."
npx lint-staged
if [ $? -ne 0 ]; then
  echo "❌ ESLint 위반. AGENTS.md 절대 금지 패턴 확인."
  exit 1
fi

# 전체 TypeScript 검사는 pre-commit 대신 npm run harness:check / npm run check 사용
# (부분 커밋 시 프로젝트 전체 tsc는 스테이징 범위와 맞지 않음)

# [H-04] console.log — staged 파일만
echo "  console.log 잔류 검사 (staged)..."
for file in $STAGED; do
  case "$file" in
    *.ts|*.svelte)
      if grep -n "console\.log" "$file" 2>/dev/null | grep -v "// harness-allow"; then
        echo "❌ console.log 잔류: $file"
        echo "  제거 또는 줄 끝에 // harness-allow 추가."
        exit 1
      fi
      ;;
  esac
done

# [H-03] any 타입 — staged 파일만
echo "  any 타입 잔류 검사 (staged)..."
for file in $STAGED; do
  case "$file" in
    *.ts|*.svelte)
      if grep -n ": any\b" "$file" 2>/dev/null | grep -v "// harness-allow"; then
        echo "❌ any 타입 잔류: $file"
        exit 1
      fi
      ;;
  esac
done

# [GP-10] 기존 마이그레이션 파일 수정 감지 (Added 제외, Modified만 차단)
echo "  마이그레이션 파일 수정 감지..."
MODIFIED=$(git diff --cached --name-only --diff-filter=M 2>/dev/null | grep "supabase/migrations/" || true)
if [ -n "$MODIFIED" ]; then
  echo "❌ 기존 마이그레이션 파일 수정 감지:"
  echo "$MODIFIED"
  echo "  새 마이그레이션 파일로 ALTER 처리하세요. (GP-10)"
  exit 1
fi

# [CS-01] 서버 키 노출 — static/public import 줄에 secret 키가 있을 때만
echo "  서버 키 노출 검사 (staged)..."
for file in $STAGED; do
  case "$file" in
    *.ts|*.svelte)
      if grep "static/public" "$file" 2>/dev/null \
        | grep -E "TOSS_SECRET_KEY|SERVICE_ROLE_KEY" 2>/dev/null \
        | grep -v "// harness-allow" >/dev/null; then
        echo "❌ 서버 전용 키가 public import에서 감지됨: $file"
        echo "  \$env/static/private 또는 dynamic/private 에서만 import 해야 합니다. (GP-09)"
        exit 1
      fi
      ;;
  esac
done

# [BC-01] Boundary Rules — boundary-validator는 staged 파일만 검사
echo "  경계 규칙 검사 (staged)..."
if [ -f "scripts/boundary-validator.cjs" ]; then
  node scripts/boundary-validator.cjs || {
    echo "❌ 경계 규칙 위반."
    echo "   상세: .claude/harness/learnings/boundary_violations.md"
    exit 1
  }
fi

echo ""
echo "✅ Harness pre-commit 검사 통과."
echo ""
exit 0
